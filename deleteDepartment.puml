@startuml
skinparam sequenceArrowThickness 2
skinparam roundcorner 5
skinparam sequenceParticipant underline

actor "Usuario / Admin" as User

participant "DepartmentListComponent\n(Angular)" as UI
participant "DepartmentController\nDELETE /departments/{id}" as Controller
participant "DepartmentService" as Service
participant "DepartmentRepository" as Repo
database "MongoDB\n(departments)" as DB

== Eliminar Departamento ==

User -> UI : Click "Eliminar" en una fila
activate UI

UI -> UI : remove(department)
UI --> User : confirm("Eliminar '...'?")

alt Usuario cancela
    User -> UI : Click "Cancelar"
    UI --> User : Cierra diálogo
else Usuario confirma
    User -> UI : Click "Aceptar"

    UI -> UI : api.delete('/departments/{id}')

    UI -> Controller : DELETE /departments/{id} + JWT
    activate Controller

    Controller -> Service : remove(id)
    activate Service

    Service -> Service : findOne(id)
    Service -> Repo : findById(id)
    activate Repo
    Repo -> DB : SELECT * FROM departments\nWHERE id=?
    activate DB
    DB --> Repo : Optional<Department>
    deactivate DB

    alt Departamento no encontrado
        Repo --> Service : Optional.empty()
        deactivate Repo
        Service --> Controller : 404 Not Found\n"Departamento no encontrado"
        Controller --> UI : 404 Not Found
        UI --> User : snack.open('Error al eliminar', ...)
    else Departamento existe
        Repo --> Service : Optional[Department]
        deactivate Repo

        Service -> Repo : deleteById(id)
        activate Repo
        Repo -> DB : DELETE FROM departments\nWHERE id=?
        activate DB
        DB --> Repo : OK
        deactivate DB
        Repo --> Service : void
        deactivate Repo
        Service --> Controller : void
        deactivate Service
        Controller --> UI : 204 No Content
        deactivate Controller
        UI -> UI : load()
        UI --> User : snack.open('Eliminado', ...)
    end
end

deactivate UI

@enduml
