@startuml
skinparam sequenceArrowThickness 2
skinparam roundcorner 5
skinparam sequenceParticipant underline

actor "Usuario / Admin" as User

participant "DepartmentListComponent\n(Angular)" as UI
participant "DepartmentController\nGET|POST|PATCH|DELETE /departments" as Controller
participant "DepartmentService" as Service
participant "DepartmentRepository" as Repo
participant "CompanyRepository" as CompanyRepo
database "MongoDB\n(departments)" as DB

== Listar Departamentos ==

User -> UI : Navega a /departments
activate UI

UI -> Controller : GET /departments\n[?companyId] + JWT
activate Controller

Controller -> Service : findAll(companyId)
activate Service

alt companyId != null
    Service -> Repo : findByCompanyIdOrderByNameAsc(companyId)
else companyId == null
    Service -> Repo : findAll()
end

activate Repo
Repo -> DB : SELECT * FROM departments\n[WHERE companyId=?]
activate DB
DB --> Repo : List<Department>
deactivate DB
Repo --> Service : List<Department>
deactivate Repo
Service --> Controller : List<Department>
deactivate Service
Controller --> UI : 200 OK – List<Department>
deactivate Controller

UI -> UI : Renderiza tabla
UI --> User : Muestra departamentos
deactivate UI

== Crear Departamento ==

User -> UI : Click "Nuevo Departamento"
activate UI
UI --> User : Muestra formulario modal

User -> UI : Ingresa name, description, companyId
User -> UI : Click "Guardar"

UI -> Controller : POST /departments\n{companyId, name, description} + JWT
activate Controller

Controller -> Service : create(body)
activate Service

Service -> CompanyRepo : findById(companyId)
activate CompanyRepo
CompanyRepo -> DB : SELECT * FROM companies\nWHERE id=?
activate DB
DB --> CompanyRepo : Optional<Company>
deactivate DB

alt Company no encontrada
    CompanyRepo --> Service : Optional.empty()
    deactivate CompanyRepo
    Service --> Controller : 400 Bad Request\n"Empresa no encontrada"
    Controller --> UI : 400 Bad Request
    UI --> User : Toast error "Empresa no encontrada"
else Company existe
    CompanyRepo --> Service : Optional[Company]
    deactivate CompanyRepo

    Service -> Service : new Department()\n.setCompanyId(company.getId())\n.setName(name)\n.setDescription(description)

    Service -> Repo : save(department)
    activate Repo
    Repo -> DB : INSERT INTO departments\n{companyId, name, description,\ncreatedAt, updatedAt}
    activate DB
    DB --> Repo : Department (con id generado)
    deactivate DB
    Repo --> Service : Department
    deactivate Repo
    Service --> Controller : Department
    deactivate Service
    Controller --> UI : 201 Created – Department
    deactivate Controller
    UI -> UI : showForm = false\nrecarga lista
    UI --> User : Toast "Departamento creado"
end

deactivate UI

== Consultar Departamento ==

User -> UI : Click en una fila
activate UI

UI -> Controller : GET /departments/{id} + JWT
activate Controller

Controller -> Service : findOne(id)
activate Service

Service -> Repo : findById(id)
activate Repo
Repo -> DB : SELECT * FROM departments\nWHERE id=?
activate DB
DB --> Repo : Optional<Department>
deactivate DB

alt Departamento no encontrado
    Repo --> Service : Optional.empty()
    deactivate Repo
    Service --> Controller : 404 Not Found\n"Departamento no encontrado"
    Controller --> UI : 404 Not Found
    UI --> User : Toast error "No encontrado"
else Departamento existe
    Repo --> Service : Optional[Department]
    deactivate Repo
    Service --> Controller : Department
    deactivate Service
    Controller --> UI : 200 OK – Department
    deactivate Controller
    UI --> User : Muestra detalle
end

deactivate UI

== Actualizar Departamento ==

User -> UI : Click "Editar" en una fila
activate UI
UI --> User : Muestra formulario pre-cargado

User -> UI : Modifica name / description / companyId
User -> UI : Click "Guardar"

UI -> Controller : PATCH /departments/{id}\n{name?, description?, companyId?} + JWT
activate Controller

Controller -> Service : update(id, body)
activate Service

Service -> Repo : findById(id)
activate Repo
Repo -> DB : SELECT * FROM departments\nWHERE id=?
activate DB
DB --> Repo : Optional<Department>
deactivate DB

alt Departamento no encontrado
    Repo --> Service : Optional.empty()
    deactivate Repo
    Service --> Controller : 404 Not Found\n"Departamento no encontrado"
    Controller --> UI : 404 Not Found
    UI --> User : Toast error "No encontrado"
else Departamento existe
    Repo --> Service : Optional[Department]
    deactivate Repo

    alt body contiene "companyId"
        Service -> CompanyRepo : findById(companyId)
        activate CompanyRepo
        CompanyRepo -> DB : SELECT * FROM companies\nWHERE id=?
        activate DB
        DB --> CompanyRepo : Optional<Company>
        deactivate DB

        alt Company no encontrada
            CompanyRepo --> Service : Optional.empty()
            deactivate CompanyRepo
            Service --> Controller : 400 Bad Request\n"Empresa no encontrada"
            Controller --> UI : 400 Bad Request
            UI --> User : Toast error "Empresa no encontrada"
        else Company existe
            CompanyRepo --> Service : Optional[Company]
            deactivate CompanyRepo
            Service -> Service : department.setCompanyId(companyId)
        end
    end

    Service -> Service : Aplica name / description\nsi presentes en body

    Service -> Repo : save(department)
    activate Repo
    Repo -> DB : UPDATE departments\nSET name=?, description=?,\nupdatedAt=? WHERE id=?
    activate DB
    DB --> Repo : Department actualizado
    deactivate DB
    Repo --> Service : Department
    deactivate Repo
    Service --> Controller : Department
    deactivate Service
    Controller --> UI : 200 OK – Department
    deactivate Controller
    UI -> UI : editId = null\nrecarga lista
    UI --> User : Toast "Departamento actualizado"
end

deactivate UI

== Eliminar Departamento ==

User -> UI : Click "Eliminar" en una fila
activate UI
UI --> User : Diálogo de confirmación

alt Usuario cancela
    User -> UI : Click "Cancelar"
    UI --> User : Cierra diálogo
else Usuario confirma
    User -> UI : Click "Confirmar"

    UI -> Controller : DELETE /departments/{id} + JWT
    activate Controller

    Controller -> Service : remove(id)
    activate Service

    Service -> Repo : findById(id)
    activate Repo
    Repo -> DB : SELECT * FROM departments\nWHERE id=?
    activate DB
    DB --> Repo : Optional<Department>
    deactivate DB

    alt Departamento no encontrado
        Repo --> Service : Optional.empty()
        deactivate Repo
        Service --> Controller : 404 Not Found\n"Departamento no encontrado"
        Controller --> UI : 404 Not Found
        UI --> User : Toast error "No encontrado"
    else Departamento existe
        Repo --> Service : Optional[Department]
        deactivate Repo

        Service -> Repo : deleteById(id)
        activate Repo
        Repo -> DB : DELETE FROM departments\nWHERE id=?
        activate DB
        DB --> Repo : OK
        deactivate DB
        Repo --> Service : void
        deactivate Repo
        Service --> Controller : void
        deactivate Service
        Controller --> UI : 204 No Content
        deactivate Controller
        UI -> UI : Recarga lista
        UI --> User : Toast "Departamento eliminado"
    end
end

deactivate UI

@enduml
